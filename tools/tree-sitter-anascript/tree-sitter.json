{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "anascript",
      "camelcase": "Anascript",
      "title": "Anascript",
      "scope": "source.anascript",
      "file-types": [
        "ana",
        "anascript"
      ],
      "injection-regex": "^anascript$",
      "class-name": "TreeSitterAnascript"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Small Lisp that is also a JSON superset.",
    "authors": [
      {
        "name": "Jonathan Claggett",
        "email": "jonathan@claggett.org",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-anascript",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
